<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nothing_black"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/nothing_black"
        app:title="NEW RULE"
        app:titleTextColor="@color/nothing_white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/nothing_white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. SELECT APP"
                android:textColor="@color/nothing_grey_4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/NothingCard"
                android:layout_marginBottom="24dp">
                <Spinner
                    android:id="@+id/appSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/nothing_white" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. SELECT ANIMATION"
                android:textColor="@color/nothing_grey_4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/NothingCard"
                android:layout_marginBottom="24dp">
                <Spinner
                    android:id="@+id/animSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/nothing_white" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. SETTINGS"
                android:textColor="@color/nothing_grey_4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/NothingCard"
                android:layout_marginBottom="32dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/durationLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DURATION: 3S"
                        android:textColor="@color/nothing_white"
                        android:textSize="12sp"
                        android:letterSpacing="0.05" />
                    <SeekBar
                        android:id="@+id/durationSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="30"
                        android:progress="3"
                        android:progressTint="@color/nothing_accent"
                        android:thumbTint="@color/nothing_accent"
                        android:layout_marginBottom="16dp"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/brightnessLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BRIGHTNESS: 255"
                        android:textColor="@color/nothing_white"
                        android:textSize="12sp"
                        android:letterSpacing="0.05" />
                    <SeekBar
                        android:id="@+id/brightnessSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="255"
                        android:progress="255"
                        android:progressTint="@color/nothing_accent"
                        android:thumbTint="@color/nothing_accent"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="SAVE RULE"
                style="@style/NothingButton.Accent" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>