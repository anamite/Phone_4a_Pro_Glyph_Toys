<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nothing_black"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/nothing_black"
        app:title="GLYPH MO"
        app:titleTextColor="@color/nothing_white"
        app:titleCentered="true"
        app:titleTextAppearance="@style/NothingTitleText" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/nothing_black"
        app:tabTextColor="@color/nothing_grey_4"
        app:tabSelectedTextColor="@color/nothing_accent"
        app:tabIndicatorColor="@color/nothing_accent"
        app:tabIndicatorHeight="2dp"
        app:tabRippleColor="@null"
        app:tabTextAppearance="@style/NothingTabText" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>