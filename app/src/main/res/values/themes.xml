<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.GlyphGifToy" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/nothing_accent</item>
        <item name="android:windowBackground">@color/nothing_black</item>
        <item name="android:statusBarColor">@color/nothing_black</item>
        <item name="android:navigationBarColor">@color/nothing_black</item>
    </style>

    <style name="Theme.GlyphGifToy" parent="Base.Theme.GlyphGifToy" />

    <style name="NothingButton" parent="Widget.Material3.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Nothing</item>
        <item name="backgroundTint">@color/nothing_grey_2</item>
        <item name="android:textColor">@color/nothing_white</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="NothingButton.Accent">
        <item name="backgroundTint">@color/nothing_accent</item>
        <item name="android:textColor">@color/nothing_white</item>
    </style>

    <style name="NothingButton.Secondary">
        <item name="backgroundTint">@color/nothing_grey_3</item>
    </style>

    <style name="NothingCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/nothing_grey_1</item>
        <item name="cardCornerRadius">5dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/nothing_grey_2</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ShapeAppearance.Nothing" parent="">
        <item name="cornerSize">5dp</item>
    </style>

    <style name="GlyphBtn" parent="NothingButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="NothingTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="NothingTitleText" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/ndot57</item>
        <item name="fontFamily">@font/ndot57</item>
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
</resources>